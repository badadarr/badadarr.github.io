# ============================================================
#  .gitignore — badadarr.github.io (Static Portfolio)
# ============================================================

# ── OS files ─────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
desktop.ini

# ── Editor / IDE ─────────────────────────────────────────────
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.code-workspace

# ── Scratch / temp files ──────────────────────────────────────
*.txt
!robots.txt
*.log
*.bak
*.tmp
*.temp

# ── Node (jika suatu kali pakai build tools) ─────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json
yarn.lock
dist/
.cache/

# ── Environment ───────────────────────────────────────────────
.env
.env.local
.env.*.local
